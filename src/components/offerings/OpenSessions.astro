---
import OfferingsLayout from "../../layouts/OfferingsLayout.astro";
import MainImage from "../../assets/offerings-open-sessions-main.png";
import Button from "../ui/inputs/Button.astro";
---

<OfferingsLayout title="Open Sessions">
  <div
    class="w-full aspect-video lg:aspect-73/30 overflow-hidden border-8 border-flick-dark"
  >
    <img
      src={MainImage.src}
      alt="Open session"
      class="relative bottom-14 sm:bottom-25 lg:bottom-75 w-full object-cover aspect-4/3"
    />
  </div>
  <p class="font-light text-xl lg:text-2xl">
    Open sessions are non-supervised and designed for flexible, social play.
    Players can sign up individually and are matched with others on the day.
    With a maximum of 12 players per session, it’s a great way to get quality
    games, meet new players, and play freely in a relaxed environment.
  </p>
  <a href="https://bookwhen.com/flicktt" target="_blank" class="m-auto">
    <Button class="mb-2" size="lg">Book now</Button>
  </a>
</OfferingsLayout>
