---
import OfferingsLayout from "../../layouts/OfferingsLayout.astro";
import Button from "../ui/inputs/Button.astro";
import MainImage from "../../assets/offerings-workshops-main.png";
---

<OfferingsLayout title="Workshops">
  <div
    class="w-full aspect-video lg:aspect-73/30 overflow-hidden border-8 border-flick-dark"
  >
    <img
      src={MainImage.src}
      alt="Workshop"
      class="relative bottom-14 sm:bottom-25 lg:bottom-75 w-full object-cover aspect-4/3"
    />
  </div>
  <p class="font-light text-xl lg:text-2xl">
    Our bi-monthly workshops are topic-focused training sessions led by
    experienced coaches and are free for members. Each two-hour session dives
    deep into a specific aspect of the game—past topics include footwork,
    playing against pimples, service techniques, and other crucial table tennis
    skills. Ideal for players looking to sharpen their understanding and add new
    tools to their game.
  </p>
  <a href="https://bookwhen.com/flicktt" target="_blank" class="m-auto">
    <Button class="mb-2" size="lg">Book now</Button>
  </a>
</OfferingsLayout>
